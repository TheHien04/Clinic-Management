# Copy to .env in repo root for: docker compose up --build
# cp .env.docker.example .env

# SQL Server (must meet complexity rules for MSSQL image)
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

# Backend secrets (change for anything beyond local Docker)
JWT_SECRET=dev-docker-jwt-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=dev-docker-refresh-secret-min-32-ch!!

# Optional: set SKIP_DB_MIGRATE=1 in docker-compose if you run migrations manually
# SKIP_DB_MIGRATE=0
