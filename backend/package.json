{
  "name": "clinic-management-backend",
  "version": "1.0.0",
  "description": "Backend API for Clinic Management System",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "start:stable": "PORT=5055 PORT_FALLBACK_ATTEMPTS=1 node src/server.js",
    "dev:stable": "PORT=5055 PORT_FALLBACK_ATTEMPTS=1 nodemon src/server.js",
    "db:migrate": "node scripts/migrate.mjs",
    "db:deploy": "npm run db:migrate",
    "test": "node scripts/smoke_test.mjs",
    "test:smoke": "node scripts/smoke_test.mjs"
  },
  "keywords": ["clinic", "management", "api", "express", "sql-server"],
  "author": "TheHien04",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mssql": "^10.0.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.6.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
