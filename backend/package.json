{
  "name": "clinic-management-backend",
  "version": "1.0.0",
  "description": "Backend API for Clinic Management System",
  "main": "src/server.js",
  "type": "module",
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "start:stable": "PORT=5055 PORT_FALLBACK_ATTEMPTS=1 node src/server.js",
    "dev:stable": "PORT=5055 PORT_FALLBACK_ATTEMPTS=1 nodemon src/server.js",
    "db:migrate": "node scripts/migrate.mjs",
    "db:deploy": "npm run db:migrate",
    "test": "node scripts/smoke_test.mjs",
    "test:smoke": "node scripts/smoke_test.mjs",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest"
  },
  "keywords": [
    "clinic",
    "management",
    "api",
    "express",
    "sql-server"
  ],
  "author": "TheHien04",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.1",
    "morgan": "^1.10.0",
    "mssql": "^12.2.1",
    "multer": "^1.4.5-lts.1",
    "redis": "^4.7.1",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
