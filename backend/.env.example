# Server Configuration
PORT=5055
PORT_FALLBACK_ATTEMPTS=10
NODE_ENV=development

# Database Configuration
DB_SERVER=localhost
DB_NAME=ClinicManagement
DB_USER=sa
DB_PASSWORD=your_password_here
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# Optional NoSQL (MongoDB) Configuration
ENABLE_MONGO=false
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=ClinicManagement

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_key
JWT_REFRESH_EXPIRE=30d

# CORS
CORS_ORIGIN=http://localhost:5173
STRICT_ORIGIN_CHECK=false

# Optional CSRF (double-submit cookie)
ENABLE_CSRF_TOKEN=false
CSRF_COOKIE_NAME=csrf_token
CSRF_TOKEN_MAX_AGE_MS=7200000

# Rate limiting (security hardening)
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=60
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10

# Security audit retention
SECURITY_AUDIT_RETENTION_ENABLED=true
SECURITY_AUDIT_RETENTION_DAYS=90
SECURITY_AUDIT_RETENTION_INTERVAL_MS=86400000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# WebSocket
SOCKET_CORS_ORIGIN=http://localhost:5173
